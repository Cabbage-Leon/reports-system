generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Report {
  id          String   @id @default(cuid())
  title       String
  type        String
  typeText    String
  topic       String
  filePath    String
  fileFormat  String   @default("html") // 原始文件格式: html, markdown, pdf, docx, doc, txt
  createTime  DateTime @default(now())
  updateTime  DateTime @updatedAt
  source      String?  @default("manual") // manual, feishu, api
  sourceId    String?  // 源文档 ID（飞书文档 ID 或其他来源 ID）
  syncTime    DateTime?
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model FeishuSyncConfig {
  id              String    @id @default(cuid())
  enabled         Boolean   @default(true)
  appId           String
  appSecret       String
  userAccessToken String?   // 用户授权的访问令牌（用于个人空间）
  refreshToken    String?   // 刷新令牌
  tokenExpireTime DateTime? // token 过期时间
  folderToken     String?   // 飞书文件夹 token
  syncTime        String    @default("09:00") // 同步时间，格式 "HH:MM"
  syncRange       String    @default("today") // 同步范围: today, this_week, custom, date_range
  syncDays        Int       @default(1) // 自定义同步范围的天数
  customStartDate DateTime? // 自定义时间范围的开始日期
  customEndDate   DateTime? // 自定义时间范围的结束日期
  fileTypes       String[]  @default(["html", "md"]) // 允许的文件类型，如 ["html", "md", "docx"]
  reportType      String    @default("day") // 同步的报告类型
  topic           String    @default("飞书同步") // 同步的报告主题
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastSyncTime    DateTime?
}
