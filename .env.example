# ============================================
# 环境变量配置模板
# ============================================
# 复制此文件为 .env.local 并填入实际值
# 不要将 .env.local 提交到 Git！

# ============================================
# 开发环境 (.env.local)
# ============================================
# 本地开发需要配置 PostgreSQL 数据库
DATABASE_URL="postgresql://user:password@localhost:5432/reports_db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="开发环境密钥（使用 openssl rand -base64 32 生成）"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 本地开发不需要 Blob Token（仅 Vercel 环境需要）
# BLOB_READ_WRITE_TOKEN="local_dev_placeholder"

# ============================================
# 生产环境 (Vercel Environment Variables)
# ============================================
# 在 Vercel Dashboard -> Settings -> Environment Variables 中配置

# 1. Vercel Postgres 数据库连接
# DATABASE_URL="postgresql://..."

# 2. NextAuth 配置
# NEXTAUTH_URL="https://your-app.vercel.app"
# NEXTAUTH_SECRET="生产环境密钥（使用 openssl rand -base64 32 生成）"
# NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# 3. Vercel Blob 存储配置
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx..." （在 Vercel Storage 中自动生成）
